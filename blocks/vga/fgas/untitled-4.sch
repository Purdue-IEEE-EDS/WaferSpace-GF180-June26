C {code_shown.sym} 190 310 0 0 {name=s1 only_toplevel=false value="
.include /foss/pdks/gf180mcuD/libs.tech/ngspice/design.ngspice
.lib /foss/pdks/gf180mcuD/libs.tech/ngspice/sm141064.ngspice ss
.lib /foss/pdks/gf180mcuD/libs.tech/ngspice/sm141064.ngspice res_ss
.option method=gear

.control
save all
ac dec 40 1Meg 10G
let vdiff = v(vout) - v(vout_n)
let gain_db = db(vdiff)

meas ac maxgain MAX gain_db
meas ac f3db WHEN gain_db='maxgain-3' FALL=1

plot db(vdiff)

write \{VGA_Gilb_cell.raw\}
.endc
"
}
