# ── Read RTL ──
read_liberty -lib /foss/pdks/gf180mcuD/libs.ref/gf180mcu_fd_sc_mcu9t5v0/lib/gf180mcu_fd_sc_mcu9t5v0__tt_025C_3v30.lib
read_verilog -sv src/fft.sv src/mdc_stage.sv src/mdc_ram_delay.sv src/r2.sv src/rotator.sv src/triv_rotator.sv src/adder.sv src/CLA4.sv src/CLA16.sv src/CLA32.sv src/full_adder_cla.sv src/wallace_mult.sv src/full_adder.sv src/half_adder.sv src/carry_save_adder.sv src/commutator.sv src/twiddle_rom.sv 

# ── Elaborate hierarchy ──
hierarchy -top fft -check
# ── Post-elaborate hierarchy ──
ls

# ── Behavioral → structural ──
proc

# ── FLATTEN — dont preserve module boundaries ──

opt_clean
# ── Coarse optimisation ──
opt_expr
opt_clean
check
opt -nodffe -nosdff
wreduce
peepopt
opt_clean

# ── Arithmetic and sharing ──
alumacc
share
opt

# ── Memory ──
memory -nomap
opt_clean
opt -fast -full
memory_map
opt -full

# ── Technology mapping ──
techmap
splitnets -driver
opt -fast

opt_clean
# ── Hierarchy check before ABC ──
# ── Pre-ABC hierarchy ──
ls

# ── DFF → liberty cell mapping ──
dfflibmap -liberty /foss/pdks/gf180mcuD/libs.ref/gf180mcu_fd_sc_mcu9t5v0/lib/gf180mcu_fd_sc_mcu9t5v0__tt_025C_3v30.lib

# ── ABC: single pass, timing-driven ──
# -D 6250: delay target (ps) = clock period
# No -dff: do NOT retime across register boundaries
abc -liberty /foss/pdks/gf180mcuD/libs.ref/gf180mcu_fd_sc_mcu9t5v0/lib/gf180mcu_fd_sc_mcu9t5v0__tt_025C_3v30.lib -D 6250 

# ── Final cleanup and stats ──
opt_clean
stat -liberty /foss/pdks/gf180mcuD/libs.ref/gf180mcu_fd_sc_mcu9t5v0/lib/gf180mcu_fd_sc_mcu9t5v0__tt_025C_3v30.lib
# ── Final hierarchy ──
ls

# ── Write netlist ──
write_verilog -noattr syn/fft_syn.v
