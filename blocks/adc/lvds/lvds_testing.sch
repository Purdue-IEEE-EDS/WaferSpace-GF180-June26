C {res.sym} 480 -80 0 0 {name=R1
value=100
footprint=1206
device=resistor
m=1}
C {vsource.sym} 1170 -710 0 0 {name=V3 value=\{VDD\} savecurrent=false}
C {gnd.sym} 1170 -630 0 0 {name=l2 lab=0}
C {lab_wire.sym} 1170 -810 0 0 {name=p12 sig_type=std_logic lab=Vdd}
C {code.sym} 1420 -480 0 0 {name=s1 only_toplevel=false value="
.options temp=27

.param VDD=3.3
.param VCM=1.2

* 2 Gbps data rate
.param UI=500p
.param TR=20p
.param SEED=11

* Input timing jitter, peak-to-peak
* Set TJPP=0p for no jitter
.param TJPP=40p

* ============================================================
* Internal pseudo-random data generation with shared edge jitter
* ============================================================
.func frac(x) \{x - floor(x)\}

.func rand01(n) \{frac(sin((n + 1 + SEED)*12.9898)*43758.5453123)\}
.func rand01j(n) \{frac(sin((n + 1 + SEED)*78.233)*24634.6345)\}

.func rbit(n) \{floor(2*rand01(n))\}
.func jitter(n) \{(rand01j(n)-0.5)*TJPP\}

.func edge(x) \{0.5*(1 + tanh(x/(TR/10)))\}

.func data_bit(t) \{rbit(floor(t/UI)-1)+(rbit(floor(t/UI))-rbit(floor(t/UI)-1))*edge(t-floor(t/UI)*UI-jitter(floor(t/UI)))\}

* ============================================================
* Behavioral input sources
*
* IMPORTANT:
* Delete/disable any schematic PULSE or bsource symbols
* connected to vin_p / vin_n when using these.
* ============================================================

Bvinp vin_p 0 V=\{VDD*data_bit(time)\}
Bvinn vin_n 0 V=\{VDD*(1 - data_bit(time))\}

.control
set filetype=ascii
set wr_singlescale
set numdgt=12

shell rm /foss/designs/trans_testing/lvds_testing/lvds_eye_temp_27.txt

save v(vin_p) v(vin_n) v(vout_p) v(vout_n)

tran 2p 200n 0 2p

let vod = v(vout_p)-v(vout_n)
let vcm_out = (v(vout_p)+v(vout_n))/2
let vod_abs = abs(vod)

meas tran vcm_avg avg vcm_out from=20n to=200n
meas tran vcm_max max vcm_out from=20n to=200n
meas tran vcm_min min vcm_out from=20n to=200n

meas tran vod_abs_avg avg vod_abs from=20n to=200n
meas tran vod_max max vod from=20n to=200n
meas tran vod_min min vod from=20n to=200n

wrdata /foss/designs/trans_testing/lvds_testing/lvds_eye_temp_27.txt v(vin_p) v(vin_n) v(vout_p) v(vout_n) vod vcm_out

.endc
"}
