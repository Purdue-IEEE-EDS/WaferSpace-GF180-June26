m=1}
C {vsource.sym} 1170 -710 0 0 {name=V3 value=\{VDD\} savecurrent=false}
C {gnd.sym} 1170 -630 0 0 {name=l2 lab=0}
C {lab_wire.sym} 1170 -810 0 0 {name=p12 sig_type=std_logic lab=Vdd}
C {code.sym} 1420 -480 0 0 {name=s1 only_toplevel=false value="
.param VDD=3.3
.param VCM=1.2

* Temperature parameter used by .options
.param TEMP=27
.options temp=\{TEMP\}

* 2 Gbps
.param UI=500p
.param TR=20p
.param SEED=11

* Jitter setting
* Use 0p for no jitter, e.g. .param TJPP=0p
.param TJPP=0p

* ============================================================
* Internal pseudo-random data generation
* ============================================================

.func frac(x) \{x - floor(x)\}
.func rand01(n) \{frac(sin((n + 1 + SEED)*12.9898)*43758.5453123)\}
.func rand01j(n) \{frac(sin((n + 1 + SEED)*78.233)*24634.6345)\}
.func rbit(n) \{floor(2*rand01(n))\}
.func jitter(n) \{(rand01j(n)-0.5)*TJPP\}
.func edge(x) \{0.5*(1 + tanh(x/(TR/10)))\}
.func data_bit(t) \{rbit(floor(t/UI)-1)+(rbit(floor(t/UI))-rbit(floor(t/UI)-1))*edge(t-floor(t/UI)*UI-jitter(floor(t/UI)))\}

* ============================================================
* Behavioral input sources
* Remove/disable old PULSE sources connected to vin_p/vin_n.
* ============================================================

Bvinp vin_p 0 V=\{VDD*data_bit(time)\}



.control
set filetype=ascii
set wr_singlescale
set numdgt=12

* Folder for output data files
shell rm /foss/designs/trans_testing/lvds_testing/lvds_eye_temp_m40.txt
shell rm /foss/designs/trans_testing/lvds_testing/lvds_eye_temp_27.txt
shell rm /foss/designs/trans_testing/lvds_testing/lvds_eye_temp_125.txt

* ============================================================
* Temperature = -40 C
* ============================================================

alterparam TEMP = -40
set temp=-40
reset
save v(vin_p) v(vin_n) v(vout_p) v(vout_n) v(Vin_ph) v(Vin_nd) v(Vin_pd) v(Vout_err)

tran 2p 200n 0 2p

let vod = v(vout_p)-v(vout_n)
let vcm_out = (v(vout_p)+v(vout_n))/2
let vod_abs = abs(vod)
let id_p = @m.xm5.m0[id]
let id_n = @m.xm6.m0[id]

plot v(Vin_n) v(Vin_nd) 
plot v(Vin_pd) v(Vin_ph)
plot id_p id_n
plot v(Vout_err)


wrdata /foss/designs/trans_testing/lvds_testing/lvds_eye_temp_m40.txt v(vin_p) v(vin_n) v(vout_p) v(vout_n) vod vcm_out


meas tran td_pd_rise TRIG v(vin_ph) VAL=1.65 RISE=10 TARG v(vin_pd) VAL=1.65 RISE=10
meas tran td_pd_fall TRIG v(vin_ph) VAL=1.65 FALL=10 TARG v(vin_pd) VAL=1.65 FALL=10

meas tran td_nd_rise TRIG v(vin_n) VAL=1.65 RISE=10 TARG v(vin_nd) VAL=1.65 RISE=10
meas tran td_nd_fall TRIG v(vin_n) VAL=1.65 FALL=10 TARG v(vin_nd) VAL=1.65 FALL=10

* 50% complementary skew
meas tran skew_ph_rise_n_fall TRIG v(vin_ph) VAL=1.65 RISE=10 TARG v(vin_n)  VAL=1.65 FALL=10
meas tran skew_ph_fall_n_rise TRIG v(vin_ph) VAL=1.65 FALL=10 TARG v(vin_n)  VAL=1.65 RISE=10

* Edge times
meas tran tr_ph TRIG v(vin_ph) VAL=0.33 RISE=10 TARG v(vin_ph) VAL=2.97 RISE=10
meas tran tf_ph TRIG v(vin_ph) VAL=2.97 FALL=10 TARG v(vin_ph) VAL=0.33 FALL=10

meas tran tr_n  TRIG v(vin_n)  VAL=0.33 RISE=10 TARG v(vin_n)  VAL=2.97 RISE=10
meas tran tf_n  TRIG v(vin_n)  VAL=2.97 FALL=10 TARG v(vin_n)  VAL=0.33 FALL=10
* ============================================================
* Temperature = 27 C
* ============================================================

alterparam TEMP = 27
set temp=27
reset
save v(vin_p) v(vin_n) v(vout_p) v(vout_n) v(Vin_ph) v(Vin_nd) v(Vin_pd) v(Vout_err)

tran 2p 200n 0 2p

let vod = v(vout_p)-v(vout_n)
let vcm_out = (v(vout_p)+v(vout_n))/2
let vod_abs = abs(vod)
let id_p = @m.xm5.m0[id]
let id_n = @m.xm6.m0[id]
plot v(Vin_n) v(Vin_nd) 
plot v(Vin_pd) v(Vin_ph)
plot id_p id_n
v(Vout_err)

wrdata /foss/designs/trans_testing/lvds_testing/lvds_eye_temp_27.txt v(vin_p) v(vin_n) v(vout_p) v(vout_n) vod vcm_out


meas tran td_pd_rise TRIG v(vin_ph) VAL=1.65 RISE=10 TARG v(vin_pd) VAL=1.65 RISE=10
meas tran td_pd_fall TRIG v(vin_ph) VAL=1.65 FALL=10 TARG v(vin_pd) VAL=1.65 FALL=10

meas tran td_nd_rise TRIG v(vin_n) VAL=1.65 RISE=10 TARG v(vin_nd) VAL=1.65 RISE=10
meas tran td_nd_fall TRIG v(vin_n) VAL=1.65 FALL=10 TARG v(vin_nd) VAL=1.65 FALL=10


* 50% complementary skew
meas tran skew_ph_rise_n_fall TRIG v(vin_ph) VAL=1.65 RISE=10 TARG v(vin_n)  VAL=1.65 FALL=10
meas tran skew_ph_fall_n_rise TRIG v(vin_ph) VAL=1.65 FALL=10 TARG v(vin_n)  VAL=1.65 RISE=10

* Edge times
meas tran tr_ph TRIG v(vin_ph) VAL=0.33 RISE=10 TARG v(vin_ph) VAL=2.97 RISE=10
meas tran tf_ph TRIG v(vin_ph) VAL=2.97 FALL=10 TARG v(vin_ph) VAL=0.33 FALL=10

meas tran tr_n  TRIG v(vin_n)  VAL=0.33 RISE=10 TARG v(vin_n)  VAL=2.97 RISE=10
meas tran tf_n  TRIG v(vin_n)  VAL=2.97 FALL=10 TARG v(vin_n)  VAL=0.33 FALL=10
* ============================================================
* Temperature = 125 C
* ============================================================

alterparam TEMP = 125
set temp=125
reset
save v(vin_p) v(vin_n) v(vout_p) v(vout_n) v(Vin_ph) v(Vin_nd) v(Vin_pd) v(Vout_err)

tran 2p 200n 0 2p

let vod = v(vout_p)-v(vout_n)
let vcm_out = (v(vout_p)+v(vout_n))/2
let vod_abs = abs(vod)
plot v(Vin_n) v(Vin_nd) 
plot v(Vin_pd) v(Vin_ph)
v(Vout_err)

wrdata /foss/designs/trans_testing/lvds_testing/lvds_eye_temp_125.txt v(vin_p) v(vin_n) v(vout_p) v(vout_n) vod vcm_out


meas tran td_pd_rise TRIG v(vin_ph) VAL=1.65 RISE=10 TARG v(vin_pd) VAL=1.65 RISE=10
meas tran td_pd_fall TRIG v(vin_ph) VAL=1.65 FALL=10 TARG v(vin_pd) VAL=1.65 FALL=10

meas tran td_nd_rise TRIG v(vin_n) VAL=1.65 RISE=10 TARG v(vin_nd) VAL=1.65 RISE=10
meas tran td_nd_fall TRIG v(vin_n) VAL=1.65 FALL=10 TARG v(vin_nd) VAL=1.65 FALL=10

* 50% complementary skew
meas tran skew_ph_rise_n_fall TRIG v(vin_ph) VAL=1.65 RISE=10 TARG v(vin_n)  VAL=1.65 FALL=10
meas tran skew_ph_fall_n_rise TRIG v(vin_ph) VAL=1.65 FALL=10 TARG v(vin_n)  VAL=1.65 RISE=10

* Edge times
meas tran tr_ph TRIG v(vin_ph) VAL=0.33 RISE=10 TARG v(vin_ph) VAL=2.97 RISE=10
meas tran tf_ph TRIG v(vin_ph) VAL=2.97 FALL=10 TARG v(vin_ph) VAL=0.33 FALL=10

meas tran tr_n  TRIG v(vin_n)  VAL=0.33 RISE=10 TARG v(vin_n)  VAL=2.97 RISE=10
meas tran tf_n  TRIG v(vin_n)  VAL=2.97 FALL=10 TARG v(vin_n)  VAL=0.33 FALL=10
.endc
"}
